// Poruchka data model — multi-tenant from day one.
// RLS policies are added in a separate SQL migration (see prisma/migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum ChatChannel {
  TELEGRAM
  VIBER
  WHATSAPP
}

enum OrderRunStatus {
  PENDING
  SUBMITTED
  ESCALATED
  SKIPPED
}

/// A restaurant. Top-level tenant; everything else is scoped to it.
model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  timezone           String   @default("Europe/Sofia")
  quietHoursStart    Int      @default(22) // local hour 0-23 — no nudges from here…
  quietHoursEnd      Int      @default(8) // …until here
  renudgeIntervalMin Int      @default(60)
  maxNudges          Int      @default(5)
  language           String   @default("bg") // bot message language: "bg" | "en"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users      User[]
  suppliers  Supplier[]
  items      Item[]
  orderRules OrderRule[]
  orderRuns  OrderRun[]
  messages   MessageLog[]

  @@map("tenants")
}

model User {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  role           Role        @default(STAFF)
  chatChannel    ChatChannel @default(TELEGRAM)
  chatUserId     String? // telegram chat id / viber id — set after linking
  linkCode       String?     @unique // one-time code used to link the chat account
  supabaseAuthId String?     @unique @db.Uuid // present for web-admin login users
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderRulesAssigned   OrderRule[] @relation("OrderRuleAssignee")
  orderRulesEscalation OrderRule[] @relation("OrderRuleEscalation")
  orderRunsAssigned    OrderRun[]  @relation("OrderRunAssignee")
  orderRunsSubmitted   OrderRun[]  @relation("OrderRunSubmittedBy")

  @@index([tenantId])
  // One chat identity maps to at most one member per tenant. NULL chatUserId
  // rows stay distinct in Postgres, so unlinked members are unaffected.
  @@unique([tenantId, chatChannel, chatUserId])
  @@map("users")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      Item[]
  orderRules OrderRule[]
  orderRuns  OrderRun[]

  @@index([tenantId])
  @@map("suppliers")
}

model Item {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  supplierId String   @db.Uuid
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  unit       String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderRuleLines OrderRuleLine[]
  orderRunLines  OrderRunLine[]

  @@index([tenantId])
  @@index([supplierId])
  @@map("items")
}

/// A recurring order to one supplier: the whole basket is reminded as a single
/// message. Lines hold the items + default quantities.
model OrderRule {
  id                         String   @id @default(uuid()) @db.Uuid
  tenantId                   String   @db.Uuid
  tenant                     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId                 String   @db.Uuid
  supplier                   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  assignedUserId             String   @db.Uuid
  assignedUser               User     @relation("OrderRuleAssignee", fields: [assignedUserId], references: [id], onDelete: Restrict)
  escalationUserId           String?  @db.Uuid
  escalationUser             User?    @relation("OrderRuleEscalation", fields: [escalationUserId], references: [id], onDelete: SetNull)
  reminderTimeOfDay          String // "HH:mm" in the tenant's timezone
  recurrence                 Json // discriminated union, validated by zod in the app layer
  cutoffTime                 String? // local "HH:mm" deadline to place the order
  expectedDeliveryOffsetDays Int? // delivery lands this many days after the order
  active                     Boolean  @default(true)
  archivedAt                 DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  lines OrderRuleLine[]
  runs  OrderRun[]

  @@index([tenantId])
  @@index([tenantId, archivedAt])
  @@index([supplierId])
  @@map("order_rules")
}

/// One item on an order rule, with the quantity normally ordered.
model OrderRuleLine {
  id              String    @id @default(uuid()) @db.Uuid
  orderRuleId     String    @db.Uuid
  orderRule       OrderRule @relation(fields: [orderRuleId], references: [id], onDelete: Cascade)
  itemId          String    @db.Uuid
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  defaultQuantity Float?
  unit            String?
  notes           String?
  sortOrder       Int       @default(0)

  @@index([orderRuleId])
  @@map("order_rule_lines")
}

/// A concrete order occurrence for one day. The scheduler drives this; the
/// calendar reads it. Lines are snapshotted so history stays stable.
model OrderRun {
  id                   String         @id @default(uuid()) @db.Uuid
  tenantId             String         @db.Uuid
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderRuleId          String         @db.Uuid
  orderRule            OrderRule      @relation(fields: [orderRuleId], references: [id], onDelete: Cascade)
  supplierId           String         @db.Uuid
  supplier             Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  assignedUserId       String         @db.Uuid
  assignedUser         User           @relation("OrderRunAssignee", fields: [assignedUserId], references: [id], onDelete: Restrict)
  dueDate              DateTime       @db.Date
  dueAt                DateTime
  expectedDeliveryDate DateTime?      @db.Date
  status               OrderRunStatus @default(PENDING)
  sentCount            Int            @default(0)
  lastSentAt           DateTime?
  nextNudgeAt          DateTime?
  postponedCount       Int            @default(0)
  lastPostponedAt      DateTime?
  postponedUntil       DateTime?
  submittedAt          DateTime?
  submittedByUserId    String?        @db.Uuid
  submittedByUser      User?          @relation("OrderRunSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  skipReason           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  lines OrderRunLine[]

  @@unique([orderRuleId, dueDate]) // makes materialization idempotent
  @@index([tenantId])
  @@index([status, nextNudgeAt])
  @@map("order_runs")
}

/// A snapshotted line of a concrete order run.
model OrderRunLine {
  id               String   @id @default(uuid()) @db.Uuid
  orderRunId       String   @db.Uuid
  orderRun         OrderRun @relation(fields: [orderRunId], references: [id], onDelete: Cascade)
  itemId           String   @db.Uuid
  item             Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemNameSnapshot String
  quantitySnapshot Float?
  unitSnapshot     String?
  notesSnapshot    String?
  sortOrder        Int      @default(0)

  @@index([orderRunId])
  @@map("order_run_lines")
}

/// Audit trail of inbound/outbound chat messages, for debugging.
model MessageLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @db.Uuid
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  direction  String // "out" | "in"
  channel    ChatChannel
  chatUserId String?
  payload    Json
  createdAt  DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@map("message_logs")
}
