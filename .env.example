# ───────────────────────────────────────────────────────────────────────────
# Poruchka environment variables. Copy to apps/api/.env and fill in real values.
# NEVER put real secrets in this file — it is committed to git. Placeholders only.
# ───────────────────────────────────────────────────────────────────────────

# --- Database (Supabase Postgres) ---
# Pooled connection (Transaction pooler, port 6543) used by the running app:
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler / direct connection (port 5432) used by Prisma Migrate:
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (for verifying web-admin JWTs in the API) ---
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_JWT_SECRET="<jwt-secret-from-supabase-dashboard>"

# --- Telegram (pilot channel) ---
# Create a bot with @BotFather, paste the token here:
TELEGRAM_BOT_TOKEN="<bot-token>"
# Random string sent as Telegram's secret_token header to authenticate webhook calls:
TELEGRAM_WEBHOOK_SECRET="<random-string>"

# --- Viber (parallel track, fill once commercial bot access is granted) ---
VIBER_AUTH_TOKEN=""

# --- Runtime ---
PORT="3001"
# Public HTTPS base URL of the API (used to register the Telegram/Viber webhook):
PUBLIC_API_URL="https://<your-api-host>"
